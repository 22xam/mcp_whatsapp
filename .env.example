# ─────────────────────────────────────────
# AI Provider
# ─────────────────────────────────────────

# Which AI provider to use: "gemini", "ollama", or "openrouter"
AI_PROVIDER=gemini

# ─────────────────────────────────────────
# Gemini (Google) — used when AI_PROVIDER=gemini
# ─────────────────────────────────────────

# Get your free API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─────────────────────────────────────────
# Ollama (local/open source) — used when AI_PROVIDER=ollama
# ─────────────────────────────────────────

# URL where Ollama is running (default: local)
OLLAMA_URL=http://localhost:11434

# Set to "true" to have the bot start and stop Ollama automatically.
# Set to "false" if you prefer to run Ollama separately.
OLLAMA_AUTO_START=false

# -----------------------------------------
# OpenRouter - used when AI_PROVIDER=openrouter
# -----------------------------------------

# Get your API key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# Default OpenRouter OpenAI-compatible API base URL.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional, used by OpenRouter rankings/analytics.
# OPENROUTER_SITE_URL=https://your-site.example
OPENROUTER_APP_NAME=BugMate

# Optional, only for embedding models that support custom dimensions.
# OPENROUTER_EMBEDDING_DIMENSIONS=1536

# Run primary + fallback chat models in parallel and use the first successful answer.
OPENROUTER_RACE_MODELS=true
OPENROUTER_TIMEOUT_MS=60000
# OPENROUTER_FALLBACK_MODELS=meta-llama/llama-3.3-70b-instruct:free,qwen/qwen3-14b:free

# ─────────────────────────────────────────
# Developer Contact
# ─────────────────────────────────────────

# Your name — shown in escalation messages sent to clients
DEVELOPER_NAME=Nacho

# Your WhatsApp number in international format — digits only, no + or spaces.
# Example: Argentina (+54) → 5491123456789
DEVELOPER_PHONE=5491123456789

# ─────────────────────────────────────────
# Control Group (optional)
# ─────────────────────────────────────────

# WhatsApp group ID used to send control commands to the bot.
# To get the ID: create a group with the bot's number, then send !grupos from any group.
# Once you have it, paste it here and restart the server.
# Format: <digits>@g.us
# CONTROL_GROUP_ID=120363XXXXXXXXXX@g.us

# ─────────────────────────────────────────
# Trello (optional)
# ─────────────────────────────────────────

# Get your API Key and Token at: https://trello.com/power-ups/admin
# 1. Create a Power-Up → copy the API Key
# 2. Click "Token" next to the API Key → authorize → copy the Token
# Then use !trello in your control group to discover board and list IDs.
# TRELLO_API_KEY=your_trello_api_key_here
# TRELLO_TOKEN=your_trello_token_here

# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────

PORT=3000
BOT_OSCAR_DB_PATH=

# Optional admin API/panel token. If empty, local API remains open.
# BOT_OSCAR_ADMIN_TOKEN=change-me

# WhatsApp
# Set to false when you only want to run the API/CLI without opening WhatsApp Web.
WHATSAPP_ENABLED=true

# Optional session id for running multiple local instances without sharing the same browser profile.
# WHATSAPP_SESSION_ID=bot-oscar-dev

# Campaign worker
# Set to false if you want to process campaign jobs manually with the CLI/API.
CAMPAIGN_WORKER_ENABLED=true
CAMPAIGN_WORKER_INTERVAL_MS=5000
