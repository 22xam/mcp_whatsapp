# ─────────────────────────────────────────
# AI Provider
# ─────────────────────────────────────────

# Which AI provider to use: "gemini" or "ollama"
AI_PROVIDER=gemini

# ─────────────────────────────────────────
# Gemini (Google) — used when AI_PROVIDER=gemini
# ─────────────────────────────────────────

# Get your free API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─────────────────────────────────────────
# Ollama (local/open source) — used when AI_PROVIDER=ollama
# ─────────────────────────────────────────

# URL where Ollama is running (default: local)
OLLAMA_URL=http://localhost:11434

# Set to "true" to have the bot start and stop Ollama automatically.
# Set to "false" if you prefer to run Ollama separately.
OLLAMA_AUTO_START=false

# ─────────────────────────────────────────
# Developer Contact
# ─────────────────────────────────────────

# Your name — shown in escalation messages sent to clients
DEVELOPER_NAME=Nacho

# Your WhatsApp number in international format — digits only, no + or spaces.
# Example: Argentina (+54) → 5491123456789
DEVELOPER_PHONE=5491123456789

# ─────────────────────────────────────────
# Control Group (optional)
# ─────────────────────────────────────────

# WhatsApp group ID used to send control commands to the bot.
# To get the ID: create a group with the bot's number, then send !grupos from any group.
# Once you have it, paste it here and restart the server.
# Format: <digits>@g.us
# CONTROL_GROUP_ID=120363XXXXXXXXXX@g.us

# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────

PORT=3000
